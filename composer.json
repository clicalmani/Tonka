{
    "name": "clicalmani/tonka",
    "type": "project",
    "description": "Tonka Framework.",
    "keywords": ["framework", "tonka"],
    "license": "MIT",
    "require": {
        "clicalmani/console": ">=1.0",
        "clicalmani/database": ">=1.0",
        "clicalmani/fundation": "^v1.0.3-beta",
        "clicalmani/routing": "^1.0",
        "clicalmani/xpower": ">=1.0",
        "symfony/console": "^6.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Database\\Entities\\": "database/entities/",
            "Test\\": "test/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "beta",
    "prefer-stable": false
}
